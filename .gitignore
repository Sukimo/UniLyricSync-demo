# ===========================
# Unity 6 .gitignore
# ===========================

# Generated folders - never commit these
Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/
MemoryCaptures/

# Autogenerated VS/Rider solution & project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files - KEEP *.meta, ignore these specific generated ones
# (Meta files ARE committed - they're part of your project)

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables (runtime data, regenerated on build)
# Uncomment if you're NOT checking in addressable bundles:
# [Aa]ddressable[Aa]ssets[Dd]ata/**/[Bb]uild[Ll]og*.json
# [Aa]ddressable[Aa]ssets[Dd]ata/**/[Cc]atalog*.json
# [Aa]ddressable[Aa]ssets[Dd]ata/**/[Cc]atalog*.hash

# Asset Bundle output
AssetBundles/

# Unity Package Manager cache - ignore everything except manifest and lock files
Packages/*/
!Packages/manifest.json
!Packages/packages-lock.json

# IDE - JetBrains Rider
.idea/
*.sln.DotSettings.user

# IDE - Visual Studio
.vs/
ExportedObj/

# IDE - VS Code
.vscode/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# JetBrains Rider - Unity Debugger
.idea/

# TextMeshPro (generated, not source)
# Assets/TextMesh Pro/     <- Don't ignore, it's source
# Ignore only TMP cache if you have it in a separate cache folder

# Unity Terrain Tools baked data (optional, can be large)
# Uncomment if you want to exclude baked terrain:
# Assets/**/*.terrainlayer.meta

# Shader Graph / VFX Graph compiled outputs
# (Unity 6 generates these in Library, already excluded above)

# NavMesh baked data - keep the .asset files, ignore nothing extra
# Baked navmesh lives in Library/ which is already excluded

# Plastic SCM
.plastic/

# Git LFS - if you use LFS for large binary assets, add a .gitattributes
# and track: *.png, *.jpg, *.fbx, *.wav, *.mp3, etc.
